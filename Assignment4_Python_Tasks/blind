class Employee:
    def __init__(self, name):
        self.name = name
        
    def show_employee(self):
        print(f"Employee Name: {self.name}, Position: New Employee")
class Manager(Employee):
    def show_employee(self):
        print(f"Employee Name: {self.name}, Position: Manager")
class Developer(Employee):
    def show_employee(self):
        print(f"Employee Name: {self.name}, Position: Developer")
        

manager = Manager("Nurahmet")
developer = Developer("Ayan")
print("Manager:")
manager.show_employee()
print("Developer:")
developer.show_employee()